--config, -c <...files>:       The Foyfiles
--require, -r <...names>:      Require the given modules
--executor, -e [name]:         Custom executor to replace node, e.g. tsx/ts-node
--init, -i [ext]:              Generate the Foyfile, [ext] can be "ts" | "js", default is "js"
